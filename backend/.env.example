# ===== DATABASE =====
DATABASE_URL=postgresql://novamind:novamind_secret@localhost:5432/novamind

# ===== SECURITY =====
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== FREE AI APIs (Add your keys here) =====

# 1. GROQ — Primary, 1,000 req/day free
# Signup: https://console.groq.com/keys (no credit card)
GROQ_API_KEY=your-groq-key-here

# 2. Google Gemini — Backup, 1,500 req/day free
# Signup: https://aistudio.google.com/app/apikey (Google account)
GEMINI_API_KEY=your-gemini-key-here

# 3. OpenRouter — Secondary backup, 200 req/day
# Signup: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# ===== REDIS =====
REDIS_URL=redis://localhost:6379/0

# ===== CORS =====
CORS_ORIGINS=["http://localhost:3000","http://localhost:19006","https://novamind.app"]
